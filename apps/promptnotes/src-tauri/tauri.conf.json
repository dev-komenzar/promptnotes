{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PromptNotes",
  "version": "0.1.0",
  "identifier": "com.komenzar.promptnotes",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PromptNotes",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDOEY1Q0QwOEY4ODUzODUKUldTRlU0aVAwRnlQdk1kUzg3VWwwVjljL1Nyd2EvVWlISFJHZzQ1RUVCb2lNdU1TL3Y1UWpacUUK",
      "endpoints": [
        "https://github.com/dev-komenzar/promptnotes/releases/latest/download/latest.json"
      ]
    }
  }
}
